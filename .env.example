# ---------------------------------------------------------------------------
# DATABASE_URL — Postgres connection string. Read by Next.js and drizzle-kit.
# ---------------------------------------------------------------------------
#
# Local dev  ->  .env.local (gitignored):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/decisionbroker"
#
# Production (Neon):
#   - App runtime:  set DATABASE_URL in Vercel env vars to the POOLED string
#     (host contains "-pooler"; includes ?sslmode=require).
#   - Migrations:   put the DIRECT (non-pooled) string in .env.production.local
#     (gitignored) and run:  npm run db:migrate:prod
#
DATABASE_URL=
